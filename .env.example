# GitHub OAuth App の設定
# GitHub Settings > Developer settings > OAuth Apps > New OAuth App で取得
VITE_GITHUB_CLIENT_ID=your_github_client_id_here

# Express.js バックエンドの OAuth コールバックエンドポイント
# 開発環境: http://localhost:3001/api/oauth/callback
# 本番環境: https://your-backend-domain.com/api/oauth/callback
VITE_OAUTH_CALLBACK_URL=http://localhost:3001/api/oauth/callback
